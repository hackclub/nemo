<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "community health at a glance" %>

<div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-8">
  <div class="mn-card p-5">
    <div class="flex items-center justify-between mb-4">
      <span class="mn-icon-badge mn-icon-badge-blue">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 6 12 13 2 6"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg>
      </span>
    </div>
    <div class="mn-eyebrow mb-1">invited</div>
    <div class="mn-stat"><%= number_with_delimiter(@activation.invited) %></div>
    <p class="mn-label mt-2">analytics.mart_activation</p>
  </div>

  <div class="mn-card p-5">
    <div class="flex items-center justify-between mb-4">
      <span class="mn-icon-badge mn-icon-badge-green">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
      </span>
    </div>
    <div class="mn-eyebrow mb-1">claimed</div>
    <div class="mn-stat"><%= number_with_delimiter(@activation.claimed) %></div>
    <p class="mn-trend-up mt-2"><%= number_to_percentage(@activation.claim_rate.to_f * 100, precision: 1) %> claim rate</p>
  </div>

  <div class="mn-card p-5">
    <div class="flex items-center justify-between mb-4">
      <span class="mn-icon-badge mn-icon-badge-orange">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </span>
    </div>
    <div class="mn-eyebrow mb-1">active accounts</div>
    <div class="mn-stat"><%= number_with_delimiter(@active_members) %></div>
    <p class="mn-label mt-2">not deactivated as of snapshot</p>
  </div>

  <div class="mn-card p-5">
    <div class="flex items-center justify-between mb-4">
      <span class="mn-icon-badge mn-icon-badge-purple">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </span>
    </div>
    <div class="mn-eyebrow mb-1">posting members</div>
    <% if @participation %>
      <div class="mn-stat"><%= number_with_delimiter(@participation.posting_members) %></div>
      <p class="mn-label mt-2"><%= number_to_percentage((@participation.posting_share.to_f * 100).round(1), precision: 1) %> of active, window ending <%= @participation.window_end.strftime("%Y-%m-%d") %></p>
    <% else %>
      <div class="mn-stat">&mdash;</div>
      <p class="mn-label mt-2">no participation window loaded</p>
    <% end %>
  </div>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Growth, last <%= @growth_months.size %> months</h2>
  <div class="mn-card p-5">
    <% max_joined = [@growth_months.map(&:joined_members).max, 1].max %>
    <% @growth_months.each do |m| %>
      <div class="flex items-center gap-4 py-2">
        <span class="mn-label w-20 shrink-0"><%= m.month.strftime("%b %Y") %></span>
        <div class="mn-bar-track flex-1 h-2 rounded-full overflow-hidden">
          <div class="mn-bar-fill h-full rounded-full" style="width:<%= (m.joined_members.to_f / max_joined * 100).round(1) %>%"></div>
        </div>
        <span class="mn-label w-16 text-right"><%= number_with_delimiter(m.joined_members) %> joined</span>
        <span class="mn-label w-20 text-right"><%= number_with_delimiter(m.deactivated) %> left</span>
        <span class="<%= m.net_change >= 0 ? 'mn-trend-up' : 'mn-trend-down' %> justify-end w-16"><%= m.net_change >= 0 ? "+" : "" %><%= m.net_change %></span>
      </div>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-8">
  <div>
    <h2 class="mn-h2 mb-3">Activity distribution</h2>
    <div class="mn-card p-5">
      <% total_banded = @activity_bands.sum(&:members) %>
      <div class="mn-bar-track flex h-2.5 rounded-full overflow-hidden mb-4">
        <% @activity_bands.each do |b| %>
          <div class="mn-band-<%= b.band_order %>" style="width:<%= total_banded.positive? ? (b.members.to_f / total_banded * 100).round(2) : 0 %>%"></div>
        <% end %>
      </div>
      <% @activity_bands.each do |b| %>
        <div class="flex items-center justify-between py-1.5">
          <span class="flex items-center gap-2 mn-label">
            <span class="mn-band-<%= b.band_order %> inline-block w-2 h-2 rounded-full"></span>
            messages posted: <%= b.activity_band %>
          </span>
          <span class="mn-label"><%= number_with_delimiter(b.members) %> &middot; <%= total_banded.positive? ? number_to_percentage((b.members.to_f / total_banded * 100).round(1), precision: 1) : "0%" %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="mn-h2 mb-3">Account composition</h2>
    <div class="mn-card overflow-x-auto">
      <div class="min-w-[420px]">
        <div class="grid grid-cols-4 gap-4 px-5 py-3 border-b mn-divider">
          <span class="mn-eyebrow">type</span>
          <span class="mn-eyebrow text-right">members</span>
          <span class="mn-eyebrow text-right">claimed</span>
          <span class="mn-eyebrow text-right">messages</span>
        </div>
        <% @account_types.each do |a| %>
          <div class="grid grid-cols-4 gap-4 px-5 py-3 border-b mn-divider last:border-b-0 items-center">
            <span class="mn-label"><%= a.account_type %><%= " (guest)" if a.is_guest %></span>
            <span class="mn-label text-right"><%= number_with_delimiter(a.members) %></span>
            <span class="mn-label text-right"><%= number_with_delimiter(a.claimed) %></span>
            <span class="mn-label text-right"><%= number_with_delimiter(a.total_messages) %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Top channels</h2>
  <div class="mn-card overflow-x-auto">
    <div class="min-w-[640px]">
      <div class="grid grid-cols-6 gap-4 px-5 py-3 border-b mn-divider">
        <span class="mn-eyebrow col-span-2">channel</span>
        <span class="mn-eyebrow text-right">messages</span>
        <span class="mn-eyebrow text-right">posters</span>
        <span class="mn-eyebrow text-right">reactions</span>
        <span class="mn-eyebrow text-right">huddles</span>
      </div>
      <% @top_channels.each do |c| %>
        <div class="grid grid-cols-6 gap-4 px-5 py-3 border-b mn-divider last:border-b-0 items-center mn-card-interactive">
          <span class="col-span-2 flex items-center gap-2">
            #<%= c.name %>
            <span class="mn-badge <%= "mn-badge-pending" if c.visibility != "public" %> inline-flex items-center gap-1.5">
              <span class="badge-dot <%= c.visibility == "public" ? "mn-dot-public" : "mn-dot-private" %>"></span>
              <%= c.visibility %>
            </span>
          </span>
          <span class="mn-label text-right"><%= number_with_delimiter(c.messages_posted) %></span>
          <span class="mn-label text-right"><%= number_with_delimiter(c.members_who_posted) %></span>
          <span class="mn-label text-right"><%= number_with_delimiter(c.reactions_added) %></span>
          <span class="mn-label text-right"><%= number_with_delimiter(c.huddles_initiated) %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Onboarding funnel<%= ", #{@onboarding_funnel.cohort_month.strftime('%b %Y')} cohort" if @onboarding_funnel %></h2>
  <div class="mn-card p-5">
    <% if @onboarding_funnel %>
      <div style="height: 220px;">
        <canvas
          data-controller="chart"
          data-chart-type-value="bar"
          data-chart-data-value="<%= {
            labels: ["Invited", "Joined", "First post", "Retained day 30", "Retained day 90"],
            datasets: [{
              label: "members",
              data: [
                @onboarding_funnel.invited,
                @onboarding_funnel.joined,
                @onboarding_funnel.first_post,
                @onboarding_funnel.day_30_mature ? @onboarding_funnel.retained_day_30 : nil,
                @onboarding_funnel.day_90_mature ? @onboarding_funnel.retained_day_90 : nil
              ]
            }]
          }.to_json %>"
          data-chart-options-value="<%= { indexAxis: "y", maintainAspectRatio: false, plugins: { legend: { display: false } } }.to_json %>"
        ></canvas>
      </div>
      <% unless @onboarding_funnel.day_30_mature %>
        <p class="mn-label mt-3"><span class="mn-badge mn-badge-pending">too soon to tell</span> retention needs this cohort to age further before day-30/90 numbers mean anything</p>
      <% end %>
    <% else %>
      <p class="mn-label">no cohort data loaded yet</p>
    <% end %>
  </div>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Channel onboarding scorecard</h2>
  <div class="mn-card overflow-x-auto">
    <div class="min-w-[640px]">
      <div class="grid grid-cols-5 gap-4 px-5 py-3 border-b mn-divider">
        <span class="mn-eyebrow">channel</span>
        <span class="mn-eyebrow">month</span>
        <span class="mn-eyebrow text-right">newcomers</span>
        <span class="mn-eyebrow text-right">fast reply</span>
        <span class="mn-eyebrow text-right">90-day retention</span>
      </div>
      <% @channel_scorecard.each do |row| %>
        <% fast_reply_pct = (row.fast_reply_share.to_f * 100).round(1) %>
        <div class="grid grid-cols-5 gap-4 px-5 py-3 border-b mn-divider last:border-b-0 items-center">
          <span class="mn-label">#<%= row.channel_name %></span>
          <span class="mn-label"><%= row.post_month.strftime("%b %Y") %></span>
          <span class="mn-label text-right"><%= number_with_delimiter(row.newcomer_volume) %></span>
          <span class="<%= fast_reply_pct >= 60 ? 'mn-trend-up' : fast_reply_pct >= 30 ? 'mn-label' : 'mn-trend-down' %> text-right"><%= number_to_percentage(fast_reply_pct, precision: 1) %></span>
          <% if row.day_90_mature %>
            <% retained_pct = (row.retained_90_share.to_f * 100).round(1) %>
            <span class="<%= retained_pct >= 60 ? 'mn-trend-up' : retained_pct >= 30 ? 'mn-label' : 'mn-trend-down' %> text-right"><%= number_to_percentage(retained_pct, precision: 1) %></span>
          <% else %>
            <span class="text-right"><span class="mn-badge mn-badge-pending">TBD</span></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
  <% @fast_reply_vs_retention.each do |row| %>
    <div class="mn-card p-5">
      <div class="mn-eyebrow mb-1"><%= row.fast_reply ? "fast reply (< 1hr)" : "slower reply" %></div>
      <div class="mn-stat"><%= number_with_delimiter(row.newcomers) %> <span class="mn-label">newcomers</span></div>
      <% if row.retained_day_30_rate %>
        <p class="mn-label mt-2">day 30: <%= number_to_percentage((row.retained_day_30_rate.to_f * 100).round(1), precision: 1) %> &middot; day 90: <%= number_to_percentage((row.retained_day_90_rate.to_f * 100).round(1), precision: 1) %></p>
      <% else %>
        <p class="mn-label mt-2"><span class="mn-badge mn-badge-pending">TBD</span> not enough cohorts have aged yet</p>
      <% end %>
    </div>
  <% end %>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Onboarding recurrence</h2>
  <div class="mn-card p-5">
    <% if @recurrence_funnel %>
      <div style="height: 220px;">
        <canvas
          data-controller="chart"
          data-chart-type-value="bar"
          data-chart-data-value="<%= {
            labels: ["Created account", "Signed in", "Sent message", "Returned next day", "3rd visit in 7 days", "4th visit in 14 days"],
            datasets: [{
              label: "members",
              data: [
                @recurrence_funnel.created_account,
                @recurrence_funnel.signed_in,
                @recurrence_funnel.sent_message,
                @recurrence_funnel.returned_next_day,
                @recurrence_funnel.third_visit_in_7_days,
                @recurrence_funnel.fourth_visit_in_14_days
              ]
            }]
          }.to_json %>"
          data-chart-options-value="<%= { indexAxis: "y", maintainAspectRatio: false, plugins: { legend: { display: false } } }.to_json %>"
        ></canvas>
      </div>
      <p class="mn-label mt-3">of <%= number_with_delimiter(@recurrence_funnel.total_members) %> total known members</p>
    <% else %>
      <p class="mn-label">no data loaded yet</p>
    <% end %>
  </div>
</div>

<div class="mb-8">
  <h2 class="mn-h2 mb-3">Message depth distribution</h2>
  <div class="mn-card p-5">
    <div style="height: 220px;">
      <canvas
        data-controller="chart"
        data-chart-type-value="bar"
        data-chart-data-value="<%= {
          labels: @message_depth.map { |r| ">#{r.threshold}" },
          datasets: [{
            label: "% of members",
            data: @message_depth.map { |r| (r.share_above_threshold.to_f * 100).round(1) }
          }]
        }.to_json %>"
        data-chart-options-value="<%= { maintainAspectRatio: false, plugins: { legend: { display: false } } }.to_json %>"
      ></canvas>
    </div>
  </div>
</div>

<div class="mb-4">
  <h2 class="mn-h2 mb-3">Not yet covered</h2>
  <div class="mn-card overflow-hidden">
    <% [
      ["Response rate", "how quickly questions and posts get a reply"]
    ].each do |name, description| %>
      <div class="flex items-center justify-between px-5 py-4 border-b mn-divider last:border-b-0">
        <div>
          <p class="mn-h2 mn-h2-sm"><%= name %></p>
          <p class="mn-label mt-1"><%= description %></p>
        </div>
        <span class="mn-badge mn-badge-pending">chart delivery pending</span>
      </div>
    <% end %>
  </div>
</div>
