<% content_for :page_title, "Cases" %>
<% content_for :page_subtitle, "open conduct cases across fd" %>

<div class="grid grid-cols-3 gap-5 mb-8">
  <div class="fe-card p-5">
    <span class="fe-eyebrow">open</span>
    <div class="fe-stat mt-2"><%= @open_count %></div>
  </div>
  <div class="fe-card p-5">
    <span class="fe-eyebrow">unassigned</span>
    <div class="fe-stat mt-2"><%= @unassigned_count %></div>
  </div>
  <div class="fe-card p-5">
    <span class="fe-eyebrow">aging 5+ days</span>
    <div class="fe-stat mt-2"><%= @aging_count %></div>
  </div>
</div>

<div class="flex items-center gap-2 mb-3">
  <h2 class="fe-h2">All cases</h2>
</div>

<div class="fe-card overflow-hidden">
  <div class="grid grid-cols-5 gap-4 px-5 py-3 border-b fe-divider">
    <span class="fe-eyebrow">case</span>
    <span class="fe-eyebrow">status</span>
    <span class="fe-eyebrow">target</span>
    <span class="fe-eyebrow">assignee</span>
    <span class="fe-eyebrow">opened</span>
  </div>
  <% @cases.each do |c| %>
    <%= link_to fire_engine_case_path(c[:case_number]),
        class: "fe-card-interactive grid grid-cols-5 gap-4 px-5 py-3 border-b fe-divider last:border-b-0",
        style: "text-decoration:none; color:var(--foreground)" do %>
      <span class="fe-label">#<%= c[:case_number] %></span>
      <span>
        <span class="fe-badge <%= 'fe-badge-warn' if c[:status] == 'open' %>"><%= c[:status] %></span>
      </span>
      <span class="fe-label"><%= c[:target_user_id] %></span>
      <span class="fe-label"><%= c[:assignee] || "unassigned" %></span>
      <span class="fe-label"><%= c[:opened_at].strftime("%Y-%m-%d") %></span>
    <% end %>
  <% end %>
</div>
