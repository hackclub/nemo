<% content_for :page_title, "File a report" %>
<% content_for :page_subtitle, "goes to shroud's intake channel, same as filing via dm" %>

<div class="mb-6">
  <%= link_to "back to reports", fire_engine_reports_path, class: "fe-link" %>
</div>

<div class="fe-card p-6">
  <%= form_with url: fire_engine_reports_path, method: :post, local: true do %>
    <div class="mb-6">
      <label class="fe-label block mb-2">what happened</label>
      <%= text_area_tag :content, nil, rows: 5, class: "fe-field w-full" %>
    </div>

    <%= submit_tag "file report", class: "fe-button", data: { turbo_submits_with: "filing…" } %>
  <% end %>
</div>
