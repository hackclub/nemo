<% content_for :page_title, "Report ##{@report[:id]}" %>
<% content_for :page_subtitle, @report[:linked_case_number] ? "linked to case ##{@report[:linked_case_number]}" : "no case linked" %>

<div class="mb-6">
  <%= link_to "back to reports", fire_engine_reports_path, class: "fe-link" %>
</div>

<div class="fe-card p-6 mb-6">
  <span class="fe-eyebrow">content</span>
  <p class="mt-2"><%= @report[:content] %></p>
</div>

<div class="fe-card p-6">
  <p class="fe-label mb-4">
    current status: <span class="fe-badge <%= 'fe-badge-warn' if @report[:status] == 'open' %>"><%= @report[:status] %></span>
  </p>

  <% if @report[:linked_case_number] %>
    <p class="fe-label mb-6">
      resolved status follows <%= link_to "case ##{@report[:linked_case_number]}", fire_engine_case_path(@report[:linked_case_number]), class: "fe-link" %> once linked — marking resolved here only affects Shroud's own record.
    </p>
  <% end %>

  <div class="flex gap-3">
    <%= form_with url: fire_engine_report_path(@report[:id]), method: :patch, local: true do %>
      <%= hidden_field_tag :mark_resolved, "true" %>
      <%= submit_tag "mark resolved now", class: "fe-button" %>
    <% end %>

    <%= form_with url: fire_engine_report_path(@report[:id]), method: :patch, local: true do %>
      <%= hidden_field_tag :mark_merged, "true" %>
      <%= submit_tag "mark as duplicate", class: "fe-button" %>
    <% end %>
  </div>
</div>
