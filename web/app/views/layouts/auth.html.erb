<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mnemosyne" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="mn-shell min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
      <div class="flex items-center gap-2 mb-6 justify-center">
        <span class="mn-brand-mark"><span></span><span></span><span></span></span>
        <span class="mn-h2">Mnemosyne</span>
      </div>

      <div class="mn-card p-6">
        <%= yield %>
      </div>

      <p class="mn-label mt-6 text-center">community manager + fire engine portal</p>
    </div>
  </body>
</html>
