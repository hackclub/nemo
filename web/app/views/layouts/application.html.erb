<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mnemosyne" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Mnemosyne">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="mn-root min-h-screen">
    <header class="flex items-center justify-between px-6 py-4 border-b-2 mn-divider">
      <h1 class="mn-wordmark text-lg">Mnemosyne</h1>
      <div class="mn-stamp">hack club community intelligence</div>
    </header>

    <% if notice %>
      <p class="mn-stamp px-6 py-2 border-b mn-divider"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="mn-stamp px-6 py-2 border-b mn-divider" style="color:#b3261e"><%= alert %></p>
    <% end %>

    <main class="px-6 py-10 max-w-3xl mx-auto">
      <%= yield %>
    </main>
  </body>
</html>
