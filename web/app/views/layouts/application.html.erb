<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mnemosyne" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Mnemosyne">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="mn-shell min-h-screen">
    <input type="checkbox" id="mn-nav-toggle" class="nav-toggle-input" aria-hidden="true">
    <div class="flex min-h-screen">
      <label for="mn-nav-toggle" class="nav-scrim" aria-hidden="true"></label>

      <aside class="mn-sidebar w-64 shrink-0 px-4 py-5 flex flex-col justify-between sticky top-0 h-screen overflow-y-auto">
        <div>
          <div class="flex items-center gap-2 px-2 mb-8">
            <span class="mn-brand-mark"><span></span><span></span><span></span></span>
            <span class="mn-h2">Mnemosyne</span>
          </div>

          <nav class="flex flex-col gap-1">
            <%= link_to root_path, class: "mn-nav-item #{'is-active' if current_page?(root_path)}" do %>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
              <span>Dashboard</span>
            <% end %>
          </nav>
        </div>

        <div class="border-t mn-divider pt-4 px-2">
          <div class="mn-label mb-3">you &middot; <%= current_staff.user_id %></div>
          <% if current_staff.firefighter? %>
            <%= link_to "fire engine", fire_engine_root_path, class: "mn-link block mb-2" %>
          <% end %>
          <%= button_to "log out", logout_path, method: :delete, class: "mn-link", form: { class: "inline" } %>
        </div>
      </aside>

      <div class="flex-1 flex flex-col min-w-0">
        <header class="mn-header px-4 md:px-10 py-5 flex items-center justify-between sticky top-0 z-10 gap-4">
          <div class="flex items-center gap-3 min-w-0">
            <label for="mn-nav-toggle" class="nav-burger mn-nav-item" aria-label="toggle navigation">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </label>
            <div class="min-w-0">
              <h1 class="mn-h1"><%= content_for(:page_title) || "Dashboard" %></h1>
              <% if content_for(:page_subtitle) %>
                <p class="mn-label mt-1"><%= content_for(:page_subtitle) %></p>
              <% end %>
            </div>
          </div>
          <% if notice %>
            <p class="mn-label mn-text-success"><%= notice %></p>
          <% end %>
          <% if alert %>
            <p class="mn-label mn-text-danger"><%= alert %></p>
          <% end %>
        </header>

        <main class="flex-1 px-4 md:px-10 py-8 max-w-6xl">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
